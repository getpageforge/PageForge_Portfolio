# .env.example
# Copie este arquivo para .env e preencha com seus dados reais

# ═══════════════════════════════════════════════════════
# SUPABASE
# ═══════════════════════════════════════════════════════

# URL do projeto Supabase
# Obtém em: https://app.supabase.com/project/[seu-projeto]/settings/api
SUPABASE_URL=https://[seu-projeto].supabase.co

# Chave de Serviço (Service Role Key) - NUNCA compartilhe ou exponha no frontend!
# Use apenas no backend/API routes
# Obtém em: https://app.supabase.com/project/[seu-projeto]/settings/api
SUPABASE_SERVICE_KEY=eyJhbGc...

# Chave Anonimous (Anon Key) - Pode ser exposta no frontend
# Use apenas no cliente para operações permitidas
# Obtém em: https://app.supabase.com/project/[seu-projeto]/settings/api
SUPABASE_ANON_KEY=eyJhbGc...

# ═══════════════════════════════════════════════════════
# AUTENTICAÇÃO
# ═══════════════════════════════════════════════════════

# Senha para acessar o painel administrativo
# Use uma senha forte e segura!
ADMIN_PASSWORD=sua_senha_super_secreta_aqui

# ═══════════════════════════════════════════════════════
# AMBIENTE
# ═══════════════════════════════════════════════════════

# development | production
NODE_ENV=development

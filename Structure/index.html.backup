  <!-- ═══════════ JAVASCRIPT ═══════════ -->
  <script>
    /* ── Custom Cursor ─────────────────────────────────── */
    const cursor = document.getElementById('cursor');
    const cursorRing = document.getElementById('cursor-ring');
    let mx = -200, my = -200, rx = -200, ry = -200;
    document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; });
    (function animCursor() {
      rx += (mx - rx) * 0.14;
      ry += (my - ry) * 0.14;
      if (cursor) { cursor.style.left = mx + 'px'; cursor.style.top = my + 'px'; }
      if (cursorRing) { cursorRing.style.left = rx + 'px'; cursorRing.style.top = ry + 'px'; }
      requestAnimationFrame(animCursor);
    })();
    document.querySelectorAll('a, button, .service-card, .project-card, .skill-chip, .strategy-pillar').forEach(el => {
      el.addEventListener('mouseenter', () => document.body.classList.add('cursor-hover'));
      el.addEventListener('mouseleave', () => document.body.classList.remove('cursor-hover'));
    });

    /* ── Navbar Scroll ──────────────────────────────────── */
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      navbar.classList.toggle('scrolled', window.scrollY > 40);
    }, { passive: true });

    /* ── Hamburger / Mobile Drawer ───────────────────────── */
    const hamburger = document.getElementById('hamburger');
    const mobileDrawer = document.getElementById('mobileDrawer');
    hamburger.addEventListener('click', () => {
      const isOpen = mobileDrawer.classList.toggle('open');
      hamburger.classList.toggle('open', isOpen);
      hamburger.setAttribute('aria-expanded', isOpen);
    });
    mobileDrawer.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        mobileDrawer.classList.remove('open');
        hamburger.classList.remove('open');
        hamburger.setAttribute('aria-expanded', false);
      });
    });

    /* ── Scroll Reveal ──────────────────────────────────── */
    const revealObs = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => revealObs.observe(el));

    /* ── Smooth Anchor Scroll ───────────────────────────── */
    document.querySelectorAll('a[href^="#"]').forEach(a => {
      a.addEventListener('click', e => {
        const target = document.querySelector(a.getAttribute('href'));
        if (!target) return;
        e.preventDefault();
        const offset = 72;
        const top = target.getBoundingClientRect().top + window.scrollY - offset;
        window.scrollTo({ top, behavior: 'smooth' });
      });
    });

    /* ── Parallax Hero Blobs ────────────────────────────── */
    const blob1 = document.querySelector('.hero-blob-1');
    const blob2 = document.querySelector('.hero-blob-2');
    if (window.innerWidth > 768) {
      document.addEventListener('mousemove', e => {
        const xP = (e.clientX / window.innerWidth - 0.5) * 28;
        const yP = (e.clientY / window.innerHeight - 0.5) * 28;
        if (blob1) blob1.style.transform = `translate(${xP}px,${yP}px) scale(1.02)`;
        if (blob2) blob2.style.transform = `translate(${-xP * .6}px,${-yP * .6}px) scale(1.01)`;
      });
    }

    /* ── Card 3-D Tilt ──────────────────────────────────── */
    if (window.innerWidth > 768) {
      document.querySelectorAll('.service-card, .project-card:not(.project-wip)').forEach(card => {
        card.addEventListener('mousemove', e => {
          const r = card.getBoundingClientRect();
          const x = (e.clientX - r.left) / r.width - 0.5;
          const y = (e.clientY - r.top) / r.height - 0.5;
          card.style.transform = `perspective(900px) rotateY(${x * 5}deg) rotateX(${-y * 5}deg) translateY(-5px)`;
        });
        card.addEventListener('mouseleave', () => { card.style.transform = ''; });
      });
    }

    /* ── Mobile Touch Feedback ─────────────────────────── */
    // Enable :active states on iOS
    document.addEventListener("touchstart", () => { }, { passive: true });

    // Add temporary active class on touch/press to play shine animation
    document.querySelectorAll('.btn-primary, .btn-secondary, .nav-cta, .drawer-cta, .strategy-cta, .plan-cta, .overlay-btn, .social-btn').forEach(btn => {
      btn.addEventListener('pointerdown', () => {
        btn.classList.add('btn-active');
        setTimeout(() => btn.classList.remove('btn-active'), 600);
      });
    });
  </script>
</body>

</html>

          <li><a href="#cta">Contato</a></li>
        </ul>
        <div class="footer-social">
          <a href="https://wa.me/557999832772" class="social-btn" title="WhatsApp" target="_blank">
            <img
              src="../images/ne yani okul acılınca hergün kankim ile görüntülü konusamayacakmıyım(benden 1 yaş büyük🥲).jpg.jpeg"
              alt="WhatsApp">

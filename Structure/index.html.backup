<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=0.8">
  <title>PageForge — Páginas Que Convertem</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="../Visuals/style.css" />
</head>

<body>
  <!-- CUSTOM CURSOR -->
  <div id="cursor"></div>
  <div id="cursor-ring"></div>

  <!-- ═══════════ NAV ═══════════ -->
  <nav id="navbar">
    <div class="container nav-inner">
      <a href="#" class="nav-logo">
        <img src="../images/iconpf.png" alt="PageForge Logo" class="nav-logo-icon">
        PageForge
      </a>
      <ul class="nav-links">
        <li><a href="#services">Serviços</a></li>
        <li><a href="#portfolio">Trabalhos</a></li>
        <li><a href="#how-it-works">Como Funciona</a></li>
        <li><a href="#about">Sobre</a></li>
        <li><a href="#plans">Planos</a></li>
        <li><a href="#cta">Contato</a></li>
      </ul>
      <a href="#cta" class="nav-cta">Iniciar um Projeto</a>
      <button class="hamburger" id="hamburger" aria-label="Abrir menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- Mobile Drawer -->
  <div class="mobile-drawer" id="mobileDrawer">
    <a href="#services" class="drawer-link">Serviços</a>
    <a href="#portfolio" class="drawer-link">Trabalhos</a>
    <a href="#how-it-works" class="drawer-link">Como Funciona</a>
    <a href="#about" class="drawer-link">Sobre</a>
    <a href="#plans" class="drawer-link">Planos</a>
    <a href="#cta" class="drawer-cta">Iniciar um Projeto →</a>
  </div>

  <!-- ═══════════ HERO ═══════════ -->
  <section id="hero">
    <div class="blob hero-blob-1"></div>
    <div class="blob hero-blob-2"></div>
    <div class="container hero-inner">
      <div class="hero-badge">
        <span class="dot"></span>
        Aceitando novos projetos — vagas limitadas
      </div>
      <h1 class="hero-headline">
        Transforme Visitantes em<br>
        <span class="accent">Clientes Pagantes</span>
      </h1>
      <p class="hero-sub">
        Crio páginas web focadas em conversão — landing pages, portfólios e sites de negócios
        com design limpo, moderno e pensado para gerar resultados reais.
      </p>
      <div class="hero-ctas">
        <a href="#cta" class="btn-primary">Quero Minha Página →</a>
        <a href="#portfolio" class="btn-secondary">Ver Trabalhos</a>
      </div>
    </div>
    <div class="hero-scroll">
      <span>Role para baixo</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- ═══════════ MARQUEE ═══════════ -->
  <section id="proof">
    <div class="marquee-track">
      <span class="marquee-item"><span class="marquee-dot"></span>Landing Pages</span>
      <span class="marquee-item"><span class="marquee-dot"></span>Sites de Portfólio</span>
      <span class="marquee-item"><span class="marquee-dot"></span>Sites para Negócios</span>
      <span class="marquee-item"><span class="marquee-dot"></span>Design Focado em Conversão</span>
      <span class="marquee-item"><span class="marquee-dot"></span>Responsivo & Moderno</span>
      <span class="marquee-item"><span class="marquee-dot"></span>Entrega Rápida</span>
      <span class="marquee-item"><span class="marquee-dot"></span>HTML · CSS · JavaScript</span>
      <span class="marquee-item"><span class="marquee-dot"></span>Páginas que Vendem</span>
      <span class="marquee-item"><span class="marquee-dot"></span>Landing Pages</span>
      <span class="marquee-item"><span class="marquee-dot"></span>Sites de Portfólio</span>
      <span class="marquee-item"><span class="marquee-dot"></span>Sites para Negócios</span>
      <span class="marquee-item"><span class="marquee-dot"></span>Design Focado em Conversão</span>
      <span class="marquee-item"><span class="marquee-dot"></span>Responsivo & Moderno</span>
      <span class="marquee-item"><span class="marquee-dot"></span>Entrega Rápida</span>
      <span class="marquee-item"><span class="marquee-dot"></span>HTML · CSS · JavaScript</span>
      <span class="marquee-item"><span class="marquee-dot"></span>Páginas que Vendem</span>
    </div>
  </section>

  <!-- ═══════════ SERVICES ═══════════ -->
  <section id="services">
    <div class="container">
      <div class="services-header reveal">
        <div class="section-tag">O Que Eu Faço</div>
        <h2 class="section-headline">Serviços Focados<br>em Resultados</h2>
        <p class="section-sub">
          Cada página entregue é pensada estrategicamente — não apenas bonita,
          mas construída para guiar o visitante até a ação que você precisa.
        </p>
      </div>
      <div class="services-grid">
        <a href="/Structure/landing-pages.html" class="service-card reveal">
          <div class="service-icon">🚀</div>
          <h3 class="service-title">Landing Pages</h3>
          <p class="service-desc">
            Páginas de captura focadas em conversão, com estrutura de copywriting persuasivo,
            hierarquia visual clara e CTA que direcionam o visitante para uma única ação.
          </p>
          <span class="service-link">Saiba mais →</span>
        </a>
        <a href="/Structure/portfolio.html" class="service-card reveal reveal-d1">
          <div class="service-icon">💼</div>
          <h3 class="service-title">Sites de Portfólio</h3>
          <p class="service-desc">
            Portfólios que posicionam você como profissional de referência. Design premium,
            navegação intuitiva e apresentação de projetos que gera confiança imediata.
          </p>
          <span class="service-link">Saiba mais →</span>
        </a>
        <a href="/Structure/business-sites.html" class="service-card reveal reveal-d2">
          <div class="service-icon">🏢</div>
          <h3 class="service-title">Sites para Negócios</h3>
          <p class="service-desc">
            Presença digital profissional para pequenas e médias empresas. Páginas que comunicam
            credibilidade, detalham seus serviços e convertem visitantes em contatos.
          </p>
          <span class="service-link">Saiba mais →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════ PORTFOLIO ═══════════ -->
  <section id="portfolio">
    <div class="container">
      <div class="portfolio-header reveal">
        <div class="section-tag">Trabalhos</div>
        <h2 class="section-headline">Páginas Construídas<br>com Propósito</h2>
        <p class="section-sub">
          Projetos desenvolvidos para demonstrar o que é possível quando design e
          estratégia de conversão trabalham juntos.
        </p>
      </div>
      <div class="portfolio-grid">
        <!-- Projeto 1 -->
        <a href="../Capriccio/index.html" class="project-card reveal"
          style="text-decoration: none; color: inherit;">
          <div class="project-thumb">
            <div class="project-thumb-inner thumb-saas">
              <img src="../images/capricciopreview.png" alt="Capriccio Pizzaria" class="project-image">
            </div>
            <div class="project-overlay">
              <span class="overlay-btn">Ver Projeto →</span>
            </div>
          </div>
          <div class="project-info">
            <div class="project-tag">Site para Negócios · Projeto Pessoal</div>
            <div class="project-name">Capriccio Pizzaria</div>
            <div class="project-desc">
              Página única (landing page) focada em conversão para pizzaria, destacando cardápio, avaliações e
              facilitando pedidos diretos pelo WhatsApp.
            </div>
          </div>
        </a>
        <!-- Projeto 2 -->
        <a href="../BIASOUZAPORT/index.html" class="project-card reveal reveal-d1"
          style="text-decoration: none; color: inherit;">
          <div class="project-thumb">
            <div class="project-thumb-inner thumb-agency">
              <img src="../images/BIASOUZAPORT.png" alt="Bia Souza Portfólio" class="project-image">
            </div>
            <div class="project-overlay">
              <span class="overlay-btn">Ver Projeto →</span>
            </div>
          </div>
          <div class="project-info">
            <div class="project-tag">Portfólio · Projeto Pessoal</div>
            <div class="project-name">Bia Souza</div>
            <div class="project-desc">
              Landing page de portfólio focada em conversão para fotógrafa, destacando galerias de ensaios, depoimentos e agendamento direto pelo WhatsApp.
            </div>
          </div>
        </a>
        <!-- Projeto 3 -->
        <div class="project-card project-wip reveal reveal-d2">
          <div class="project-thumb">
            <div class="project-thumb-inner thumb-product">
              <div class="wip-placeholder">
                <div class="wip-icon">🛠️</div>
                <span class="wip-label">Em breve</span>
              </div>
            </div>
            <div class="project-overlay project-overlay-wip">
              <span class="overlay-btn overlay-btn-wip">Em andamento</span>
            </div>
          </div>
          <div class="project-info">
            <div class="project-tag">Site de Negócio · Projeto Pessoal</div>
            <div class="project-name">Projeto em andamento</div>
            <div class="project-desc">
              Este projeto está em desenvolvimento. Em breve disponível para visualização.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ HOW IT WORKS ═══════════ -->
  <section id="how-it-works">
    <div class="blob hiw-blob"></div>
    <div class="container">
      <div class="hiw-header reveal">
        <div class="section-tag">O Processo</div>
        <h2 class="section-headline">Como Funciona</h2>
        <p class="section-sub">
          Do briefing à entrega — cada etapa é pensada para garantir uma página
          que comunica, converte e representa sua marca com excelência.
        </p>
      </div>
      <div class="hiw-steps">
        <div class="hiw-step reveal">
          <div class="hiw-step-number">01</div>
          <div class="hiw-step-content">
            <div class="hiw-step-icon">📋</div>
            <h3 class="hiw-step-title">Briefing Estratégico</h3>
            <p class="hiw-step-desc">Entendimento profundo do negócio, objetivos, posicionamento e público-alvo da
              marca.</p>
          </div>
          <div class="hiw-connector"></div>
        </div>
        <div class="hiw-step reveal reveal-d1">
          <div class="hiw-step-number">02</div>
          <div class="hiw-step-content">
            <div class="hiw-step-icon">🎨</div>
            <h3 class="hiw-step-title">Estrutura & Design</h3>
            <p class="hiw-step-desc">Planejamento visual e estratégico da experiência da página — hierarquia, fluxo e
              intenção.</p>
          </div>
          <div class="hiw-connector"></div>
        </div>
        <div class="hiw-step reveal reveal-d2">
          <div class="hiw-step-number">03</div>
          <div class="hiw-step-content">
            <div class="hiw-step-icon">⚡</div>
            <h3 class="hiw-step-title">Desenvolvimento</h3>
            <p class="hiw-step-desc">Construção responsiva, otimizada e focada em performance — código limpo e
              eficiente.</p>
          </div>
          <div class="hiw-connector"></div>
        </div>
        <div class="hiw-step reveal reveal-d3">
          <div class="hiw-step-number">04</div>
          <div class="hiw-step-content">
            <div class="hiw-step-icon">🚀</div>
            <h3 class="hiw-step-title">Entrega & Evolução</h3>
            <p class="hiw-step-desc">Publicação, refinamentos finais e suporte contínuo para evolução da sua página.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ ABOUT ═══════════ -->
  <section id="about">
    <div class="container">
      <div class="about-grid">
        <div class="about-visual reveal">
          <div class="about-card">
            <div class="about-card-blob"></div>
            <div class="about-avatar">PF</div>
          </div>
          <div class="about-badge-float">
            <div class="badge-num">PageForge</div>
            <div class="badge-txt">Design &amp; Dev</div>
          </div>
          <div class="about-badge-float2">
            <div class="badge-num" style="color:var(--orange)">3 serviços</div>
            <div class="badge-txt">Landing · Portfólio<br>· Negócios</div>
          </div>
        </div>
        <div class="about-content reveal reveal-d2">
          <div class="section-tag">Sobre</div>
          <h2 class="section-headline">Páginas com<br>Intenção Real.</h2>
          <p class="about-text">
            Sou desenvolvedor front-end focado em criar páginas que <strong>comunicam valor e convertem</strong>.
            Meu trabalho começa antes do código — entendendo quem vai acessar a página, o que precisa sentir
            e qual ação precisa tomar.
          </p>
          <p class="about-text">
            Trabalho com <strong>HTML, CSS e JavaScript</strong> para entregar páginas rápidas, responsivas
            e visualmente marcantes. Cada detalhe — tipografia, espaçamento, hierarquia — existe por um motivo.
          </p>
          <p class="about-text">
            Se você precisa de uma página que só "pareça bonita", existem outras opções. Se quer algo
            pensado para <strong>gerar resultado</strong>, estou aqui para isso.
          </p>
          <div class="about-skills">
            <span class="skill-chip">HTML</span>
            <span class="skill-chip">CSS</span>
            <span class="skill-chip">JavaScript</span>
            <span class="skill-chip">Design Responsivo</span>
            <span class="skill-chip">Landing Pages</span>
            <span class="skill-chip">Foco em Conversão</span>
            <span class="skill-chip">Entrega Rápida</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ ESTRATÉGIA ANTES DO DESIGN ═══════════ -->
  <section id="strategy">
    <div class="blob strategy-blob-1"></div>
    <div class="blob strategy-blob-2"></div>
    <div class="container">
      <div class="strategy-inner reveal">
        <div class="strategy-eyebrow">
          <div class="section-tag">Metodologia</div>
        </div>
        <div class="strategy-grid">
          <div class="strategy-text-col">
            <h2 class="section-headline strategy-headline">Estratégia<br><span class="strategy-accent">Antes do
                Design</span></h2>
            <p class="strategy-lead">
              Cada projeto começa com um briefing estratégico.
            </p>
            <p class="strategy-body">
              Antes de criar qualquer página, analiso seu negócio, objetivos, posicionamento e público para construir
              algo que realmente faça sentido para sua marca.
            </p>
            <p class="strategy-body">
              Isso garante uma página mais <strong>estratégica, profissional</strong> e focada em resultado — não só
              esteticamente bonita, mas construída para converter.
            </p>
            <a href="https://thoughtful-bolt-ac9.notion.site/ebd/f26ae59d991d4fe3b75136f1888de4a1" target="_blank"
              rel="noopener" class="strategy-cta">
              <span class="strategy-cta-text">Preencher Briefing</span>
              <span class="strategy-cta-arrow">→</span>
              <span class="strategy-cta-glow"></span>
            </a>
          </div>
          <div class="strategy-visual-col">
            <div class="strategy-pillars">
              <div class="strategy-pillar reveal-d1">
                <div class="pillar-icon">🎯</div>
                <div class="pillar-content">
                  <h4 class="pillar-title">Análise do Negócio</h4>
                  <p class="pillar-desc">Entendimento do contexto, mercado e diferenciais competitivos.</p>
                </div>
              </div>
              <div class="strategy-pillar reveal-d2">
                <div class="pillar-icon">👥</div>
                <div class="pillar-content">
                  <h4 class="pillar-title">Público-Alvo</h4>
                  <p class="pillar-desc">Quem visita, o que sente e qual ação precisa realizar.</p>
                </div>
              </div>
              <div class="strategy-pillar reveal-d3">
                <div class="pillar-icon">📐</div>
                <div class="pillar-content">
                  <h4 class="pillar-title">Posicionamento</h4>
                  <p class="pillar-desc">Identidade visual, tom de voz e presença de marca.</p>
                </div>
              </div>
              <div class="strategy-pillar reveal-d4">
                <div class="pillar-icon">📈</div>
                <div class="pillar-content">
                  <h4 class="pillar-title">Foco em Resultado</h4>
                  <p class="pillar-desc">Cada elemento da página com propósito de conversão.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ PLANOS MENSAIS ═══════════ -->
  <section id="plans">
    <div class="container">
      <div class="plans-header services-header reveal">
        <div class="section-tag">Depois da Entrega</div>
        <h2 class="section-headline">Seu Site Sempre<br>em Boas Mãos</h2>
        <p class="section-sub">
          Depois que o seu site ficar pronto, você pode contar com um plano mensal.
          Cuido de tudo — manutenção, suporte e hospedagem — enquanto você foca no seu negócio.
        </p>
      </div>

      <div class="plans-notice reveal">
        <span class="plans-notice-icon">💡</span>
        <p>
          <strong>E o domínio e hospedagem?</strong>&nbsp;
          O domínio é o endereço do seu site (tipo <em>seusite.com.br</em>) — tem um custo anual simples,
          geralmente entre R$40 e R$80 por ano. Já a hospedagem pode ser incluída no plano mensal,
          sem que você precise se preocupar com nada disso.
        </p>
      </div>

      <div class="plans-grid">
        <!-- PLANO ESSENTIAL -->
        <div class="plan-card reveal">
          <div class="plan-card-inner">
            <span class="plan-badge"><span class="plan-badge-dot"></span>Essential</span>
            <h3 class="plan-name">Essencial</h3>
            <p class="plan-tagline">Para quem quer o site funcionando direitinho, sem precisar se preocupar com nada.
            </p>
            <div class="plan-price">
              <span class="plan-currency">R$</span>
              <span class="plan-amount">97</span>
              <span class="plan-period">/mês</span>
            </div>
            <div class="plan-divider"></div>
            <ul class="plan-features">
              <li><span class="plan-check">✓</span>Manutenção mensal do site</li>
              <li><span class="plan-check">✓</span>Suporte por WhatsApp</li>
              <li><span class="plan-check">✓</span>Pequenas correções quando necessário</li>
              <li><span class="plan-check">✓</span>Hospedagem contratada separadamente</li>
              <li><span class="plan-check">✓</span>Monitoramento básico do site</li>
            </ul>
            <a href="https://wa.me/557999832772" target="_blank" rel="noopener" class="plan-cta plan-cta-ghost">
              Quero esse plano →
            </a>
          </div>
        </div>

        <!-- PLANO GROWTH (destaque) -->
        <div class="plan-card plan-featured reveal reveal-d1">
          <div class="plan-card-inner">
            <div class="plan-popular-badge">Mais Popular</div>
            <span class="plan-badge"><span class="plan-badge-dot"></span>Growth</span>
            <h3 class="plan-name">Crescimento</h3>
            <p class="plan-tagline">Para quem quer um site que evolui junto com o negócio, sem esperar semanas por uma
              mudança.</p>
            <div class="plan-price">
              <span class="plan-currency">R$</span>
              <span class="plan-amount">197</span>
              <span class="plan-period">/mês</span>
            </div>
            <div class="plan-divider"></div>
            <ul class="plan-features">
              <li><span class="plan-check">✓</span>Tudo do plano Essential incluso</li>
              <li><span class="plan-check">✓</span>Até 4 alterações no site por mês</li>
              <li><span class="plan-check">✓</span>Atendimento prioritário — resposta mais rápida</li>
              <li><span class="plan-check">✓</span>Otimizações e melhorias contínuas</li>
              <li><span class="plan-check">✓</span>Hospedagem inclusa (sem custo extra)</li>
              <li><span class="plan-check">✓</span>Relatório mensal simples sobre o site</li>
            </ul>
            <a href="https://wa.me/557999832772" target="_blank" rel="noopener" class="plan-cta plan-cta-solid">
              Quero esse plano →
            </a>
          </div>
        </div>

        <!-- PLANO AUTHORITY -->
        <div class="plan-card plan-authority reveal reveal-d2">
          <div class="plan-card-inner">
            <span class="plan-badge plan-badge-gold"><span class="plan-badge-dot"></span>Authority</span>
            <h3 class="plan-name">Autoridade</h3>
            <p class="plan-tagline">Para marcas que desejam evolução contínua, otimizações estratégicas e presença
              digital mais forte.</p>
            <div class="plan-price">
              <span class="plan-currency plan-currency-gold">R$</span>
              <span class="plan-amount">297</span>
              <span class="plan-period">/mês</span>
            </div>
            <div class="plan-divider plan-divider-gold"></div>
            <ul class="plan-features">
              <li><span class="plan-check plan-check-gold">✓</span>Tudo do plano Growth incluso</li>
              <li><span class="plan-check plan-check-gold">✓</span>Melhorias contínuas de conversão</li>
              <li><span class="plan-check plan-check-gold">✓</span>Ajustes estratégicos visuais</li>
              <li><span class="plan-check plan-check-gold">✓</span>Prioridade máxima no suporte</li>
              <li><span class="plan-check plan-check-gold">✓</span>Otimizações UX/UI mensais</li>
              <li><span class="plan-check plan-check-gold">✓</span>Pequenas melhorias mensais no site</li>
              <li><span class="plan-check plan-check-gold">✓</span>Consultoria rápida mensal</li>
            </ul>
            <a href="https://wa.me/557999832772" target="_blank" rel="noopener" class="plan-cta plan-cta-authority">
              Quero esse plano →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ FINAL CTA ═══════════ -->
  <section id="cta">
    <div class="blob cta-blob"></div>
    <div class="container" style="position:relative;z-index:2">
      <div class="cta-box reveal">
        <div class="cta-box-border"></div>
        <p class="cta-eyebrow">Vamos construir juntos?</p>
        <h2 class="cta-headline">
          Sua Página Pode Ser<br>
          <span
            style="background:linear-gradient(90deg,var(--orange),var(--orange-hot));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">
            Seu Melhor Vendedor
          </span>
        </h2>
        <p class="cta-sub">
